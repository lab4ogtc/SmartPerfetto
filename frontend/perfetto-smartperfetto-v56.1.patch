+  font-weight: 600;
+
+  .pf-icon {
+    color: var(--pf-color-text-on-primary);
+  }
+
+  &:hover {
+    background: shade(var(--chat-primary), 88%);
+    border-color: shade(var(--chat-primary), 88%);
+    box-shadow: 0 2px 8px tint(var(--chat-primary), 35%);
+  }
+}
+
+.sp-critical-path-drawer {
+  position: fixed;
+  right: 18px;
+  bottom: 18px;
