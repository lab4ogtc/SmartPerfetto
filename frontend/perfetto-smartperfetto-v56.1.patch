+// ============================================================================
+// AI Chat Panel - Modern Design System
+// ============================================================================
+
+// ----------------------------------------------------------------------------
+// SCSS helpers
+// ----------------------------------------------------------------------------
+
+// tint($c, $p)  — base color × alpha$p laid over transparent. Used for
+//                 low-contrast overlays like hover backgrounds / alert tints.
+// shade($c, $p) — base color × alpha$p laid over black. Used for darker
+//                 hover states on solid-colored buttons.
+@function tint($color, $pct) {
+  @return color-mix(in srgb, $color $pct, transparent);
+}
+
+@function shade($color, $pct) {
+  @return color-mix(in srgb, $color $pct, black);
+}
+
+// ----------------------------------------------------------------------------
+// Theme tokens
+//
+// The AI floating window is portal-mounted to <body> (see
+// ai_floating_window.ts:setupFloatingWindow), so .ai-panel lives outside the
+// .pf-theme-provider subtree that normally defines --pf-color-*. We therefore
+// self-inject Perfetto's token set here. Dark mode is driven by ai_panel.ts
+// setting data-theme="dark" based on the OS prefers-color-scheme query.
+// ----------------------------------------------------------------------------
+
+.ai-panel {
+  // ── Light mode tokens ──────────────────────────────────────────────────
+  // Values mirror theme_provider.scss .pf-theme-provider--light exactly.
+  --pf-color-background: #ffffff;
+  --pf-color-background-secondary: #edf0f1;
+  --pf-color-background-tertiary: #e3e9eb;
+  --pf-color-text: #333333;
+  --pf-color-text-muted: #75797c;
+  --pf-color-text-hint: #808080;
+  --pf-color-border: #cccccc;
+  --pf-color-border-secondary: #e0e0e0;
+  --pf-color-primary: #3d5688;
+  --pf-color-text-on-primary: #ffffff;
+  --pf-color-interactive-base: rgb(4, 33, 56);
+  --pf-color-accent: #2667e7;
+  --pf-color-text-on-accent: #ffffff;
+  --pf-color-success: rgb(0, 128, 0);
+  --pf-color-text-on-success: #ffffff;
+  --pf-color-warning: rgb(232, 158, 0);
+  // text-on-warning is dark because Perfetto's warning is a warm orange that
+  // needs dark text for AA contrast.
+  --pf-color-text-on-warning: var(--pf-color-text);
+  --pf-color-danger: rgb(202, 38, 38);
+  --pf-color-text-on-danger: #ffffff;
+  --pf-color-box-shadow: rgba(0, 0, 0, 0.2);
+  // Sidebar surface tokens used by ai_floating_window.ts STYLES.titlebar so
+  // the title bar reads as Perfetto chrome rather than a 3rd-party overlay.
+  --pf-sidebar-surface: #262f3c;
+  --pf-sidebar-on-surface: #c8c8c8;
+  // Chart palette slot 7 (purple) used by .entity-cell to color entity IDs.
+  --pf-chart-color-7: #9334e6;
+
+  // ── --chat-* alias layer ───────────────────────────────────────────────
+  // Aliases onto the Perfetto tokens above. These names are kept because the
+  // rest of this file has hundreds of var(--chat-*) call sites; renaming all
+  // of them would be a large diff with little value. Because CSS variables
+  // resolve at use time, switching data-theme="dark" transparently re-skins
+  // every consumer through this alias layer.
+  --chat-bg: var(--pf-color-background);
+  --chat-bg-secondary: var(--pf-color-background-secondary);
+  --chat-bg-tertiary: var(--pf-color-background-tertiary);
+  --chat-text: var(--pf-color-text);
+  --chat-text-secondary: var(--pf-color-text-muted);
+  --chat-text-muted: var(--pf-color-text-hint);
+  --chat-border: var(--pf-color-border);
+  --chat-border-light: var(--pf-color-border-secondary);
+
+  --chat-primary: var(--pf-color-primary);
+  --chat-primary-hover: var(--pf-color-interactive-base);
+  --chat-primary-light: tint(var(--pf-color-primary), 10%);
+  --chat-solid-primary: var(--pf-color-primary);
+
+  // Subtle slate-blue gradient (primary → primary lightened 80% with white).
+  --chat-gradient: linear-gradient(
+    135deg,
+    var(--pf-color-primary),
+    color-mix(in srgb, var(--pf-color-primary) 80%, white)
+  );
+
+  --chat-user-bubble: var(--chat-solid-primary);
+  --chat-user-text: var(--pf-color-text-on-primary);
+  --chat-ai-bubble: var(--pf-color-background-secondary);
+  --chat-ai-border: var(--pf-color-border);
+
+  --chat-success: var(--pf-color-success);
+  --chat-warning: var(--pf-color-warning);
+  --chat-error: var(--pf-color-danger);
+
+  // Metric card status backgrounds — single source of truth for the 12% tint
+  // used by METRIC_STATUS_STYLES in ai_panel.ts. Keeps color-mix expressions
+  // in SCSS (where tint() is available) instead of duplicating them in TS.
+  --chat-metric-bg-good: tint(var(--chat-success), 12%);
+  --chat-metric-bg-warning: tint(var(--chat-warning), 12%);
+  --chat-metric-bg-critical: tint(var(--chat-error), 12%);
+  --chat-metric-bg-info: tint(var(--pf-color-accent), 12%);
+
+  --chat-shadow-sm: 0 1px 2px var(--pf-color-box-shadow);
+  --chat-shadow-md: 0 4px 12px var(--pf-color-box-shadow);
+  --chat-shadow-lg: 0 8px 24px var(--pf-color-box-shadow);
+  --chat-shadow-primary: 0 4px 14px tint(var(--pf-color-primary), 25%);
+
+  --chat-code-bg: var(--pf-color-background-tertiary);
+  --chat-code-text: var(--pf-color-danger);
+
+  --chat-scrollbar: var(--pf-color-border);
+  --chat-scrollbar-hover: var(--pf-color-text-muted);
+
+  // Tracks Perfetto's chart slot 7 so entity cells follow dark mode.
+  --chat-entity-color: var(--pf-chart-color-7);
+}
+
+// ── Dark mode override ──────────────────────────────────────────────────
+// Driven by ai_panel.ts detectDarkMode() watching OS prefers-color-scheme.
+// Only re-declares --pf-color-* (+ sidebar + chart-7) — the --chat-* aliases
+// above resolve through them at use time, so every consumer re-skins for free.
+// Values mirror theme_provider.scss .pf-theme-provider--dark.
+.ai-panel[data-theme="dark"] {
+  --pf-color-background: #202020;
+  --pf-color-background-secondary: #343434;
+  --pf-color-background-tertiary: #4a4a4a;
+  --pf-color-text: #dce0e2;
+  --pf-color-text-muted: #a0a2a5;
+  --pf-color-text-hint: #9aa0a6;
+  --pf-color-border: #484848;
+  --pf-color-border-secondary: #383838;
+  --pf-color-primary: #598bed;
+  --pf-color-text-on-primary: #333333;
+  --pf-color-interactive-base: white;
+  --pf-color-accent: #2667e7;
+  --pf-color-text-on-accent: #ffffff;
+  --pf-color-success: rgb(99, 192, 99);
+  --pf-color-text-on-success: #333333;
+  --pf-color-warning: rgb(244, 188, 67);
+  --pf-color-text-on-warning: #333333;
+  --pf-color-danger: rgb(230, 90, 90);
+  --pf-color-text-on-danger: #333333;
+  --pf-color-box-shadow: rgba(0, 0, 0, 0.4);
+  // In dark mode Perfetto sidebars reuse background-secondary — no distinct
+  // deep-slate surface — so the floating titlebar flattens into the rest of
+  // the chrome.
+  --pf-sidebar-surface: #343434;
+  --pf-sidebar-on-surface: #dce0e2;
+  --pf-chart-color-7: #c58af9;
+}
+
+// ----------------------------------------------------------------------------
+// Critical Path Assistant
+// ----------------------------------------------------------------------------
+
+.sp-critical-path-inline-btn {
