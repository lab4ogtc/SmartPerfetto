+    cursor: not-allowed;
+  }
+
+  &--readonly {
+    cursor: default;
+
+    &:hover {
+      background: transparent;
+      color: var(--chat-text-secondary);
+    }
+  }
+}
+
+.ai-header-layout-switch {
+  display: flex;
+  align-items: center;
+  gap: 2px;
+  padding: 2px;
+  border-radius: 999px;
+  background: var(--chat-bg-tertiary);
+
+  button {
