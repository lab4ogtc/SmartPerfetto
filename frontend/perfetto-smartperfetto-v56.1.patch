+    }
+  });
+
+  it('does not reload hidden or offline pages for stale lease heartbeat failures', async () => {
+    const recoveryEvents: unknown[] = [];
+    const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});
