+                        else this.effectiveRevealedKeys.add(key);
+                        m.redraw();
+                      },
+                    },
+                    isRevealed ? '🙈' : '👁️',
+                  )
+                : null,
+            ],
+          ),
+        ]);
+      }),
+    );
+  }
