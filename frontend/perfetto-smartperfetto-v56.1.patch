+      console.warn('[AIPanel] SSE session recovery returned retryable error:', {
+        status: response.status,
+        code,
+        errorText,
+      });
+      return 'transientError';
+    } catch (error) {
+      console.warn('[AIPanel] SSE session recovery failed:', error);
+      return 'transientError';
+    }
