+// ----------------------------------------------------------------------------
+// Messages Container
+// ----------------------------------------------------------------------------
+
+.ai-messages {
+  flex: 1;
+  overflow-y: auto;
+  overflow-x: hidden;
+  padding: 12px 8px;
+  display: flex;
+  flex-direction: column;
+  gap: 10px;
+
+  &::-webkit-scrollbar {
+    width: 6px;
+  }
+
+  &::-webkit-scrollbar-track {
+    background: transparent;
+  }
+
+  &::-webkit-scrollbar-thumb {
+    background: var(--chat-scrollbar);
+    border-radius: 3px;
+
+    &:hover {
+      background: var(--chat-scrollbar-hover);
+    }
+  }
+}
+
+// Empty state - compact
+.ai-empty-state {
+  flex: 1;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  padding: 20px 16px;
+  text-align: center;
+
+  .ai-empty-icon {
+    width: 40px;
+    height: 40px;
+    border-radius: 10px;
+    background: var(--chat-gradient);
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    margin-bottom: 10px;
+
+    .pf-icon {
+      font-size: 20px;
+      color: white;
+    }
+  }
+
+  h3 {
+    margin: 0 0 4px;
+    font-size: 14px;
+    font-weight: 600;
+    color: var(--chat-text);
+  }
+
+  p {
+    margin: 0;
+    font-size: 12px;
+    color: var(--chat-text-secondary);
+    max-width: 240px;
+  }
+}
+
+// ----------------------------------------------------------------------------
+// Message Component
+// ----------------------------------------------------------------------------
+
+.ai-message {
+  display: flex;
+  gap: 0;
+  max-width: 100%;
+  animation: messageSlideIn 0.2s ease-out;
+
+  &.ai-message-user {
+    align-self: flex-end;
+    flex-direction: row-reverse;
+    max-width: 85%;
+  }
+
+  &.ai-message-assistant {
+    align-self: flex-start;
+    max-width: 96%;
+  }
+}
+
+.ai-message-progress {
+  gap: 4px;
+  max-width: 88%;
+  animation-duration: 0.15s;
+}
+
+@keyframes messageSlideIn {
+  from {
+    opacity: 0;
+    transform: translateY(12px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+// Paragraph-level progressive reveal for assistant message blocks.
+// Each block-level child fades in with a staggered delay set via JS.
+@keyframes revealBlock {
+  from {
+    opacity: 0;
+    transform: translateY(8px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+.ai-message-content > .ai-reveal-block {
+  opacity: 0;
+  animation: revealBlock 0.3s ease-out forwards;
+}
+
+// Avatar - hidden (avatarless layout)
+.ai-avatar {
+  display: none;
+}
+
+.ai-avatar-user {
+  display: none;
+}
+
+.ai-avatar-assistant {
+  display: none;
+}
+
+// Wrapper for bubble + model-badge (stacks vertically)
+.ai-bubble-wrapper {
+  display: flex;
+  flex-direction: column;
+  min-width: 0;
+
+  .ai-message-user & {
+    align-items: flex-end;
+  }
+
+  .ai-message-assistant & {
+    align-items: flex-start;
+  }
+}
+
+// Message Content
+.ai-msg-wrapper {
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+  min-width: 0;
+  flex: 1;
+}
+
+.ai-msg-content,
+.ai-bubble {
+  padding: 6px 10px;
+  border-radius: 6px;
+  word-wrap: break-word;
+  overflow-wrap: anywhere;
+  position: relative;
+  flex: 0 1 auto;
+  min-width: 0;
+  font-size: 13px;
+  line-height: 1.4;
+
+  .ai-message-user & {
+    background: var(--chat-user-bubble);
+    color: var(--chat-user-text);
+    border-radius: 6px;
+    box-shadow: var(--chat-shadow-sm);
+  }
+
+  .ai-message-assistant & {
+    background: var(--chat-ai-bubble);
+    border: 1px solid var(--chat-ai-border);
+    border-radius: 6px;
+    color: var(--chat-text);
+  }
+}
+
+// Alias for user/assistant bubble
+.ai-bubble-user {
+  background: var(--chat-user-bubble) !important;
+  color: var(--chat-user-text) !important;
+  border-radius: 6px !important;
+  box-shadow: var(--chat-shadow-sm);
+}
+
+.ai-bubble-assistant {
+  background: var(--chat-ai-bubble) !important;
+  border: 1px solid var(--chat-ai-border) !important;
+  border-radius: 6px !important;
+  color: var(--chat-text) !important;
+}
+
+.ai-bubble-progress {
+  padding: 4px 8px !important;
+  background: var(--chat-bg-secondary) !important;
+  border: 1px solid var(--chat-border-light) !important;
+  box-shadow: none !important;
+}
+
+.ai-message-content-progress {
+  font-size: 12px;
+  line-height: 1.35;
+
+  p {
+    margin: 0 0 2px;
+  }
+
+  h2 {
+    margin: 2px 0 3px;
+    font-size: 1.02em;
+  }
+
+  h3 {
+    margin: 2px 0;
+    font-size: 0.92em;
+  }
+
+  ul,
+  ol {
+    margin: 2px 0;
+  }
+
+  li {
+    margin: 1px 0;
+  }
+}
+
+// Force transcript text to remain selectable even if outer containers disable selection.
+.ai-messages,
+.ai-message,
+.ai-bubble,
+.ai-msg-text,
+.ai-message-content,
+.ai-message-content * {
+  -webkit-user-select: text !important;
+  user-select: text !important;
+}
+
+// Alias for message content text
+.ai-msg-text,
+.ai-message-content {
+  line-height: 1.52;
+
+  p {
+    margin: 0 0 6px;
+
+    &:last-child {
+      margin-bottom: 0;
+    }
+  }
+
+  code {
+    background: var(--chat-code-bg);
+    color: var(--chat-code-text);
+    padding: 2px 6px;
+    border-radius: 4px;
+    font-family: "SF Mono", Monaco, "Cascadia Code", "Roboto Mono", monospace;
+    font-size: 0.9em;
+
+    .ai-message-user & {
+      background: rgba(255, 255, 255, 0.2);
+      color: inherit;
+    }
+  }
+
+  pre {
+    margin: 12px 0;
+    padding: 12px;
+    background: var(--chat-bg-tertiary);
+    border-radius: 8px;
+    overflow-x: auto;
+
+    code {
+      background: none;
+      padding: 0;
+      color: var(--chat-text);
+    }
+  }
+
+  strong {
+    font-weight: 600;
+  }
+
+  a {
+    color: var(--chat-primary);
+    text-decoration: none;
+
+    &:hover {
+      text-decoration: underline;
+    }
+
+    .ai-message-user & {
+      color: inherit;
+      text-decoration: underline;
+    }
+  }
+
+  ul,
+  ol {
+    margin: 8px 0;
+    padding-left: 20px;
+  }
+
+  li {
+    margin: 4px 0;
+  }
+}
+
+// Keep interactive controls non-selectable while allowing text copy in message body.
+.ai-message-content button,
+.ai-message-content summary,
+.ai-message-content .ai-clickable-timestamp {
+  -webkit-user-select: none !important;
+  user-select: none !important;
+}
+
+// Message Meta (timestamp, actions)
+.ai-msg-meta {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 0 4px;
+  opacity: 0;
+  transition: opacity 0.15s ease;
+
+  .ai-message:hover & {
+    opacity: 1;
+  }
+}
+
+.ai-msg-time {
+  font-size: 11px;
+  color: var(--chat-text-muted);
+}
+
+.ai-msg-actions {
+  display: flex;
+  gap: 2px;
+}
+
+.ai-msg-action {
+  width: 24px;
+  height: 24px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  background: transparent;
+  border: none;
+  border-radius: 4px;
+  color: var(--chat-text-muted);
+  cursor: pointer;
+  transition: all 0.15s ease;
+
+  .pf-icon {
+    font-size: 16px;
+  }
+
+  &:hover {
+    background: var(--chat-bg-secondary);
+    color: var(--chat-text);
+  }
+}
+
+// ----------------------------------------------------------------------------
+// Loading / Thinking State - compact
+// ----------------------------------------------------------------------------
+
+.ai-thinking {
+  display: flex;
+  gap: 8px;
+  align-self: flex-start;
+  max-width: 90%;
+}
+
+.ai-thinking-content {
+  padding: 8px 12px;
+  background: var(--chat-ai-bubble);
+  border: 1px solid var(--chat-ai-border);
+  border-radius: 6px;
+  display: flex;
+  align-items: center;
+  gap: 6px;
+}
+
+.ai-thinking-text {
+  font-size: 12px;
+  color: var(--chat-text-secondary);
+}
+
+.ai-thinking-cursor {
+  width: 2px;
+  height: 14px;
+  background: var(--chat-primary);
+  border-radius: 1px;
+  animation: cursorBlink 1s infinite;
+}
+
+@keyframes cursorBlink {
+  0%,
+  50% {
+    opacity: 1;
+  }
+  51%,
+  100% {
+    opacity: 0;
+  }
+}
+
+.ai-typing-dots,
+.ai-typing-indicator {
+  display: flex;
+  align-items: center;
+  gap: 3px;
+  padding: 2px 0;
+}
+
+.ai-typing-dot {
+  width: 6px;
+  height: 6px;
+  border-radius: 50%;
+  background: var(--chat-primary);
+  animation: dotBounce 1.4s infinite ease-in-out;
+
+  &:nth-child(1) {
+    animation-delay: -0.32s;
+  }
+  &:nth-child(2) {
+    animation-delay: -0.16s;
+  }
+  &:nth-child(3) {
+    animation-delay: 0s;
+  }
+}
+
+@keyframes dotBounce {
+  0%,
+  80%,
+  100% {
+    transform: scale(0.6);
+    opacity: 0.4;
+  }
+  40% {
+    transform: scale(1);
+    opacity: 1;
+  }
+}
+
+.ai-typing-phase {
+  margin-left: 6px;
+  font-size: 11px;
+  color: var(--chat-text-secondary);
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  max-width: calc(100% - 40px); // Adapt to bubble width minus dots
+  align-self: center;
+  opacity: 0.85;
+}
+
+// Context indicator (below messages, above input)
+.ai-context-indicator {
+  font-size: 11px;
+  color: var(--chat-text-secondary);
+  padding: 2px 8px;
+  margin-bottom: 4px;
+  opacity: 0.8;
+}
+
+// ----------------------------------------------------------------------------
+// Slice Selected Card
+
+.sp-sel-card {
+  margin: 4px 8px 6px;
+  border: 1px solid #bfdbfe;
+  border-radius: 10px;
+  background: #eff6ff;
+  overflow: hidden;
+  flex-shrink: 0;
+}
+
+.sp-sel-card-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 6px 10px;
+  background: #dbeafe;
+  border-bottom: 1px solid #bfdbfe;
+}
+
+.sp-sel-card-title {
+  font-weight: 600;
+  font-size: 12px;
+  color: #1e3a8a;
+}
+
+.sp-sel-card-dismiss {
+  background: none;
+  border: none;
+  cursor: pointer;
+  color: #6b7280;
+  font-size: 13px;
+  line-height: 1;
+  padding: 0 2px;
+
+  &:hover {
+    color: #374151;
+  }
+}
+
+.sp-sel-card-meta {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 5px;
+  padding: 7px 10px;
+}
+
+.sp-meta-pill {
+  display: inline-flex;
+  align-items: center;
+  gap: 3px;
+  padding: 2px 7px;
+  background: #fff;
+  border: 1px solid #bfdbfe;
+  border-radius: 10px;
+  font-size: 11px;
+  color: #1e40af;
+  white-space: nowrap;
+
+  strong {
+    font-weight: 600;
+  }
+}
+
+.sp-sel-card-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 5px;
+  padding: 5px 10px 9px;
+}
+
+.sp-action-btn {
+  padding: 4px 10px;
+  border-radius: 7px;
+  font-size: 12px;
+  font-weight: 500;
+  cursor: pointer;
+  border: 1px solid transparent;
+  transition: background 0.15s;
+  white-space: nowrap;
+
+  &:disabled {
+    opacity: 0.4;
+    cursor: default;
+  }
+}
+
+.sp-action-btn--primary {
+  background: #2563eb;
+  color: #fff;
+  border-color: #2563eb;
+
+  &:hover:not(:disabled) {
+    background: #1d4ed8;
+  }
+}
+
+.sp-action-btn--secondary {
+  background: #fff;
+  color: #1e40af;
+  border-color: #bfdbfe;
+
+  &:hover:not(:disabled) {
+    background: #dbeafe;
+  }
+}
+
+// ----------------------------------------------------------------------------
+// Input Area
+// ----------------------------------------------------------------------------
+
+// Input Area - compact for height efficiency
+.ai-input-area {
+  padding: 6px 8px 8px;
+  border-top: 1px solid var(--chat-border);
+  background: var(--chat-bg);
+  flex-shrink: 0;
+}
+
+.ai-input-container,
+.ai-input-wrapper {
+  position: relative;
+  display: flex;
+  flex-direction: column;
+  align-items: stretch;
+  gap: 4px;
+  min-height: 78px;
+  padding: 8px 4px 4px 12px;
+  background: var(--chat-bg-secondary);
+  border: 1px solid var(--chat-border);
+  border-radius: 6px;
+  transition: all 0.15s ease;
+
+  &:focus-within {
+    border-color: var(--chat-primary);
+    box-shadow: 0 0 0 2px var(--chat-primary-light);
+  }
+}
+
+.ai-input-controls {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  min-width: 0;
+}
+
+.ai-input-control-spacer {
+  flex: 1;
+  min-width: 12px;
+}
+
+.ai-mode-selector {
+  position: relative;
+  flex-shrink: 0;
+}
+
+.ai-mode-trigger {
+  height: 28px;
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  padding: 0 7px;
+  border: none;
+  border-radius: 6px;
+  color: var(--chat-text-secondary);
+  background: transparent;
+  font: inherit;
+  font-size: 12px;
+  font-weight: 500;
+  cursor: pointer;
+  white-space: nowrap;
+  transition:
+    background 0.15s ease,
+    color 0.15s ease;
+
+  &:hover {
+    background: var(--chat-bg-tertiary);
+    color: var(--chat-text);
+  }
+
+  .pf-icon {
+    font-size: 15px;
+  }
+}
+
+.ai-mode-trigger-icon {
+  font-size: 13px;
+}
+
+.ai-mode-menu {
+  position: absolute;
+  right: 0;
+  bottom: calc(100% + 8px);
+  z-index: 20;
+  min-width: 126px;
+  padding: 4px;
+  border: 1px solid var(--chat-border);
+  border-radius: 8px;
+  background: var(--chat-bg);
+  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
+}
+
+.ai-mode-menu-item {
+  width: 100%;
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  padding: 7px 8px;
+  border: none;
+  border-radius: 6px;
+  background: transparent;
+  color: var(--chat-text);
+  font: inherit;
+  font-size: 12px;
+  cursor: pointer;
+  text-align: left;
+
+  &:hover:not(:disabled):not(.active) {
+    background: var(--chat-bg-secondary);
+  }
+
+  &.active {
+    background: var(--chat-primary-light);
+    color: var(--chat-primary);
+    font-weight: 600;
+  }
+
+  &.disabled,
+  &:disabled {
+    opacity: 0.5;
+    cursor: not-allowed;
+  }
+
+  .pf-icon {
+    margin-left: auto;
+    font-size: 14px;
+  }
+}
+
+.ai-mode-menu-icon {
+  width: 16px;
+  text-align: center;
+}
+
+.ai-mode-menu-label {
+  white-space: nowrap;
+}
+
+.ai-input {
+  width: 100%;
+  min-height: 38px;
+  max-height: 180px;
+  padding: 2px 4px 4px 0;
+  border: none;
+  background: transparent;
+  color: var(--chat-text);
+  font-family: inherit;
+  font-size: 13px;
+  line-height: 1.4;
+  resize: vertical;
+  outline: none;
+
+  &::placeholder {
+    color: var(--chat-text-muted);
+  }
+
+  &:disabled {
+    opacity: 0.6;
+    cursor: not-allowed;
+  }
+}
+
+.ai-send-btn {
+  width: 28px;
+  height: 28px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  // Solid slate-blue fill instead of the previous purple gradient — keeps
+  // the button readable as a "primary" without competing visually with the
+  // rest of the Perfetto chrome around it.
+  background: var(--chat-solid-primary);
+  border: none;
+  border-radius: 6px;
+  color: var(--chat-user-text);
+  cursor: pointer;
+  transition:
+    filter 0.15s ease,
+    box-shadow 0.15s ease,
+    background 0.15s ease;
+  flex-shrink: 0;
+
+  .pf-icon {
+    font-size: 16px;
+  }
+
+  // Hover and active feedback use brightness/box-shadow rather than scale
+  // so the button doesn't grow into the input field on hover.
+  &:hover:not(:disabled) {
+    filter: brightness(1.08);
+    box-shadow: var(--chat-shadow-md);
+  }
+
+  &:active:not(:disabled) {
+    filter: brightness(0.92);
+  }
+
+  &:disabled {
+    background: var(--chat-border);
+    cursor: not-allowed;
+
+    .pf-icon {
+      opacity: 0.5;
+    }
+  }
+
+  &.sending {
+    background: var(--chat-solid-primary);
+
+    .pf-icon {
+      animation: spin 1s linear infinite;
+    }
+  }
+
+  &.ai-stop-btn {
+    background: var(--chat-error);
+
+    &:hover {
+      filter: brightness(1.08);
+      box-shadow: var(--chat-shadow-md);
+    }
+  }
+}
+
+.ai-input-divider {
+  width: 1px;
+  height: 20px;
+  background: var(--chat-border);
+  flex-shrink: 0;
+}
+
+@keyframes spin {
+  from {
+    transform: rotate(0deg);
+  }
+  to {
+    transform: rotate(360deg);
+  }
+}
+
+.ai-input-hint {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 2px 4px 0;
+  font-size: 10px;
+  color: var(--chat-text-muted);
+}
+
+// Warning message - compact
+.ai-warning {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  margin-top: 4px;
+  padding: 6px 10px;
+  background: tint(var(--chat-warning), 10%);
+  border: 1px solid tint(var(--chat-warning), 20%);
+  border-radius: 6px;
+  font-size: 11px;
+  color: var(--chat-warning);
+
+  .pf-icon {
+    font-size: 14px;
+  }
+}
+
+// Inline connecting indicator — animated progress during background upload
+.ai-connecting-indicator {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  gap: 8px;
+  margin: 8px 12px;
+  padding: 8px 12px;
+  background: tint(var(--pf-color-accent), 8%);
+  border: 1px solid tint(var(--pf-color-accent), 20%);
+  border-radius: 8px;
+  font-size: 12px;
+  color: var(--pf-color-accent);
+
+  .pf-icon {
+    font-size: 16px;
+    flex-shrink: 0;
+    animation: pulse 2s ease-in-out infinite;
+  }
+
+  .ai-upload-progress {
+    width: 100%;
+    margin-top: 4px;
+  }
+}
+
+@keyframes pulse {
+  0%,
+  100% {
+    opacity: 1;
+  }
+  50% {
+    opacity: 0.4;
+  }
+}
+
+// Inline disconnect banner — shown inside messages area when backend drops mid-conversation
+.ai-disconnect-banner {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  margin: 8px 12px;
+  padding: 8px 12px;
+  background: tint(var(--chat-error), 8%);
+  border: 1px solid tint(var(--chat-error), 20%);
+  border-radius: 8px;
+  font-size: 12px;
+  color: var(--chat-error);
+
+  .pf-icon {
+    font-size: 16px;
+    flex-shrink: 0;
+  }
+
+  span {
+    flex: 1;
+  }
+
+  .ai-disconnect-retrying {
+    font-size: 11px;
+    opacity: 0.7;
+  }
+}
+
+.ai-disconnect-retry-btn {
+  padding: 3px 10px;
+  border: 1px solid tint(var(--chat-error), 30%);
+  border-radius: 4px;
+  background: transparent;
+  color: var(--chat-error);
+  font-size: 11px;
+  cursor: pointer;
+  white-space: nowrap;
+
+  &:hover {
+    background: tint(var(--chat-error), 10%);
+  }
+}
+
+// Model change annotation — plain muted text, no bubble
+.ai-model-badge {
+  display: block;
+  margin-top: 3px;
+  font-size: 11px;
+  font-family: monospace;
+  color: var(--chat-text-muted, #888);
+  text-align: right;
+}
+
+.ai-feedback-bar {
+  display: flex;
+  gap: 4px;
+  margin-top: 4px;
+  opacity: 0;
+  transition: opacity 0.15s;
+
+  .ai-message:hover & {
+    opacity: 1;
+  }
+}
+
+.ai-feedback-btn {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  width: 24px;
+  height: 24px;
+  border: none;
+  border-radius: 4px;
+  background: transparent;
+  color: var(--chat-text-muted);
+  cursor: pointer;
+  padding: 0;
+
+  .pf-icon {
+    font-size: 14px;
+  }
+
+  &:hover {
+    background: var(--chat-bg-secondary);
+    color: var(--chat-text);
+  }
+
+  &.active {
+    color: var(--chat-primary);
+    opacity: 1;
+  }
+}
+
+// Sub-agent status cards — visual indicators of parallel evidence collection
+.ai-sub-agent-cards {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+  margin-top: 8px;
+}
+
+.ai-sub-agent-card {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  padding: 6px 10px;
+  border-radius: 6px;
+  font-size: 11px;
+  border: 1px solid var(--chat-border);
+  background: var(--chat-bg-secondary);
+  min-width: 180px;
+  flex: 1;
+
+  &.sub-agent-running {
+    border-color: tint(var(--pf-color-accent), 30%);
+    background: tint(var(--pf-color-accent), 5%);
+  }
+
+  &.sub-agent-completed {
+    border-color: tint(var(--chat-success), 30%);
+    background: tint(var(--chat-success), 5%);
+  }
+
+  &.sub-agent-failed,
+  &.sub-agent-stopped {
