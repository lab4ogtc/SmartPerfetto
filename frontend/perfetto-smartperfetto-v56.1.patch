+}
+
+.sp-critical-path-metric,
+.sp-critical-path-card {
+  border: 1px solid var(--chat-border-light, var(--chat-border, #dadce0));
+  border-radius: 8px;
+  background: color-mix(in srgb, var(--chat-bg, #fff) 94%, var(--chat-bg-secondary, #edf0f1));
+}
+
+.sp-critical-path-metric {
