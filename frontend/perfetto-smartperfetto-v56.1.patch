+}
+
+export const TYPE_ICONS: Record<ProviderType, string> = {
+  anthropic: '\u{1F916}',
+  bedrock: '☁️',
+  vertex: '\u{1F537}',
+  deepseek: '\u{1F40B}',
+  glm: '智',
+  qwen: '通',
+  qwen_coding: '码',
+  kimi_code: 'K',
+  kimi: '月',
+  doubao: '豆',
+  minimax: 'M',
+  xiaomi: '米',
+  tencent_token_plan: '腾',
