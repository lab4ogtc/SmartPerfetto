+}
+
+.sp-critical-path-card {
+  margin: 12px 14px;
+  padding: 12px;
+
+  h3 {
+    margin: 0 0 9px;
+    color: var(--chat-text, #202124);
+    font-size: 14px;
+    font-weight: 750;
+  }
+}
+
+.sp-critical-path-ai-card h3 {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 10px;
+
+  span {
+    border: 1px solid var(--chat-border-light, var(--chat-border, #dadce0));
+    border-radius: 999px;
+    padding: 3px 8px;
+    color: var(--chat-text-secondary, #5f6368);
+    font-size: 10px;
+    font-weight: 600;
+  }
+}
+
+.sp-critical-path-ai-card .sp-critical-path-status {
+  margin: 8px 0 0;
+}
+
+.sp-critical-path-summary p {
+  margin: 0 0 8px;
+  color: var(--chat-text, #202124);
+  font-size: 13px;
+  line-height: 1.6;
+}
+
+.sp-critical-path-facts,
+.sp-critical-path-evidence {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+
+  span {
+    border: 1px solid var(--chat-border-light, var(--chat-border, #dadce0));
+    border-radius: 999px;
+    padding: 4px 8px;
+    background: var(--chat-bg, #fff);
+    color: var(--chat-text-secondary, #5f6368);
+    font-size: 11px;
+  }
+}
+
+.sp-critical-path-facts {
+  margin-top: 10px;
+}
+
+.sp-critical-path-anomaly {
+  border-left: 3px solid var(--chat-border, #dadce0);
+  padding: 8px 0 8px 10px;
+
+  + .sp-critical-path-anomaly {
+    border-top: 1px solid var(--chat-border-light, var(--chat-border, #dadce0));
+  }
+
+  &.critical {
+    border-left-color: var(--chat-error, #ca2626);
+  }
+
+  &.warning {
+    border-left-color: var(--chat-warning, #e89e00);
+  }
+
+  &.info {
+    border-left-color: var(--chat-primary, #3d5688);
+  }
+
+  b {
+    color: var(--chat-text, #202124);
+    font-size: 12px;
+  }
+
+  p {
+    margin: 4px 0 7px;
+    color: var(--chat-text-secondary, #5f6368);
+    font-size: 12px;
+    line-height: 1.5;
+  }
+}
+
+.sp-critical-path-chain-row {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr);
+  gap: 10px;
+  border-top: 1px solid var(--chat-border-light, var(--chat-border, #dadce0));
+  padding: 10px 0;
+
+  &:first-child {
+    border-top: 0;
+    padding-top: 0;
+  }
+
+  b {
+    color: var(--chat-text, #202124);
+    font-size: 12px;
+  }
+
+  p {
+    margin: 4px 0 7px;
+    color: var(--chat-text-secondary, #5f6368);
+    font-size: 12px;
+    line-height: 1.5;
+  }
+}
+
+.sp-critical-path-chain-index {
+  display: grid;
+  width: 24px;
+  height: 24px;
+  place-items: center;
+  border-radius: 999px;
+  background: tint(var(--chat-primary, #3d5688), 12%);
+  color: var(--chat-primary, #3d5688);
+  font-size: 11px;
+  font-weight: 750;
+}
+
+.sp-critical-path-module-row {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 10px;
+  border-top: 1px solid var(--chat-border-light, var(--chat-border, #dadce0));
+  padding: 9px 0;
+
+  &:first-child {
+    border-top: 0;
+    padding-top: 0;
+  }
+
+  span {
+    min-width: 0;
+  }
+
+  b {
+    color: var(--chat-text, #202124);
+    font-size: 12px;
+  }
+
+  small {
+    display: block;
+    margin-top: 3px;
+    color: var(--chat-text-secondary, #5f6368);
+    font-size: 11px;
+    overflow-wrap: anywhere;
+  }
+
+  strong {
+    color: var(--chat-warning, #e89e00);
+    font-size: 12px;
+    white-space: nowrap;
+  }
+}
+
+.sp-critical-path-list {
+  display: grid;
+  gap: 7px;
+  margin: 0;
+  padding-left: 18px;
+  color: var(--chat-text, #202124);
+  font-size: 12px;
+  line-height: 1.55;
+}
+
+.sp-critical-path-muted {
+  color: var(--chat-text-secondary, #5f6368);
+  font-size: 12px;
+  line-height: 1.55;
+}
+
+@media (max-width: 640px) {
+  .sp-critical-path-drawer {
+    right: 8px;
+    bottom: 8px;
+    width: calc(100vw - 16px);
+    max-height: calc(100vh - 16px);
+  }
+
+  .sp-critical-path-metrics {
+    grid-template-columns: 1fr;
+  }
+}
+
+// ----------------------------------------------------------------------------
+// Base Panel Layout
+// ----------------------------------------------------------------------------
+
+.ai-panel {
+  display: flex;
+  flex-direction: column;
+  height: 100%;
+  overflow: hidden;
+  background: var(--chat-bg);
+  color: var(--chat-text);
+  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
+    "Helvetica Neue", sans-serif;
+  font-size: 14px;
+  line-height: 1.5;
+}
+
+// ----------------------------------------------------------------------------
+// Header
+// ----------------------------------------------------------------------------
+
+// Compact header - optimized for height
+.ai-header {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 8px;
+  padding: 4px 8px;
+  min-height: 28px;
+  border-bottom: 1px solid var(--chat-border);
+  background: var(--chat-bg);
+  flex-shrink: 0;
+}
+
+.ai-header-left {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  min-width: 0;
+}
+
+.ai-header-icon {
+  font-size: 16px !important;
+  color: var(--chat-primary);
+}
+
+.ai-header-title {
+  font-size: 12px;
+  font-weight: 600;
+  color: var(--chat-text);
+}
+
+.ai-version-chip {
+  display: inline-flex;
+  align-items: center;
+  height: 18px;
+  padding: 0 5px;
+  border: 1px solid var(--chat-border);
+  border-radius: 4px;
+  background: var(--chat-bg-secondary);
+  color: var(--chat-text-secondary);
+  font-family: monospace;
+  font-size: 10px;
+  font-weight: 600;
+  line-height: 1;
+  white-space: nowrap;
+}
+
+.ai-status-dot {
+  width: 5px;
+  height: 5px;
+  border-radius: 50%;
+  background: var(--chat-error);
+  flex-shrink: 0;
+
+  &.connected {
+    background: var(--chat-success);
+  }
+
+  &.disconnected {
+    background: var(--chat-error);
+  }
+
+  &.backend {
+    background: var(--chat-success);
+    margin-left: 4px;
+  }
+
+  // SSE streaming connection states
+  &.sse-connecting {
+    background: var(--chat-warning);
+    animation: sse-pulse 1.5s ease-in-out infinite;
+  }
+
+  &.sse-connected {
+    background: var(--chat-success);
+    animation: sse-pulse 2s ease-in-out infinite;
+  }
+
+  &.sse-reconnecting {
+    background: var(--chat-error);
+    animation: sse-pulse 0.8s ease-in-out infinite;
+  }
+}
+
+@keyframes sse-pulse {
+  0%,
+  100% {
+    opacity: 1;
+  }
+  50% {
+    opacity: 0.3;
+  }
+}
+
+.ai-status-text {
+  font-size: 11px;
+  color: var(--chat-text-secondary);
+  white-space: nowrap;
+
+  &.backend {
+    font-size: 10px;
+    color: var(--chat-success);
+  }
+
+  &.snapshot {
+    display: inline-flex;
+    align-items: center;
+    gap: 3px;
+    max-width: 96px;
+    height: 18px;
+    padding: 0 5px;
+    border: 1px solid var(--chat-border);
+    border-radius: 4px;
+    background: var(--chat-bg-secondary);
+    color: var(--chat-primary);
+    font-size: 10px;
+    overflow: hidden;
+    text-overflow: ellipsis;
+
+    .pf-icon {
+      font-size: 12px !important;
+      flex-shrink: 0;
+    }
+  }
+}
+
+.ai-workspace-chip {
+  display: inline-flex;
+  align-items: center;
+  gap: 3px;
+  max-width: 150px;
+  height: 20px;
+  padding: 0 6px;
+  border: 1px solid var(--chat-border);
+  border-radius: 6px;
+  background: var(--chat-bg-secondary);
+  color: var(--chat-text-secondary);
+  cursor: pointer;
+  font-size: 10px;
+  font-weight: 600;
+  min-width: 0;
+
+  .pf-icon {
+    font-size: 13px !important;
+    flex-shrink: 0;
+  }
+
+  span {
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+
+  &:hover {
+    color: var(--chat-text);
+    background: var(--chat-bg-tertiary);
+  }
+}
+
+// Preset question buttons, now hosted in the input bar control row.
+.ai-preset-questions {
+  display: flex;
+  align-items: center;
+  gap: 4px;
+  min-width: 0;
+  overflow: hidden;
+}
+
+.ai-preset-btn {
+  display: flex;
+  align-items: center;
+  gap: 3px;
+  padding: 2px 8px;
+  font-size: 11px;
+  font-weight: 500;
+  color: var(--chat-text-secondary);
+  background: var(--chat-bg-secondary);
+  border: 1px solid var(--chat-border);
+  border-radius: 12px;
+  cursor: pointer;
+  transition: all 0.15s ease;
+  white-space: nowrap;
+
+  .pf-icon {
+    font-size: 12px !important;
+  }
+
+  &:hover:not(:disabled) {
+    color: var(--chat-primary);
+    background: var(--chat-bg-tertiary);
+    border-color: var(--chat-primary);
+  }
+
+  &:active:not(:disabled) {
+    transform: scale(0.95);
+  }
+
+  &:disabled {
+    opacity: 0.5;
+    cursor: not-allowed;
+  }
+}
+
+.ai-smart-inline-actions {
+  margin-top: 12px;
+  padding-top: 10px;
+  border-top: 1px solid var(--chat-border);
+}
+
+.ai-smart-scene-preview {
+  margin-top: 12px;
+  border: 1px solid var(--chat-border);
+  border-radius: 8px;
+  background: var(--chat-bg-secondary);
+  overflow: hidden;
+}
+
+.ai-smart-scene-preview-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  padding: 10px 12px;
+  border-bottom: 1px solid var(--chat-border);
+}
+
+.ai-smart-scene-preview-title,
+.ai-smart-scene-preview-counts {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+  min-width: 0;
+}
+
+.ai-smart-scene-preview-title {
+  color: var(--chat-text);
+  font-size: 13px;
+  font-weight: 700;
+
+  .pf-icon {
+    color: var(--pf-color-accent);
+    font-size: 16px !important;
+  }
+}
+
+.ai-smart-scene-preview-counts {
+  flex-wrap: wrap;
+  justify-content: flex-end;
+  color: var(--chat-text-secondary);
+  font-size: 12px;
+}
+
+.ai-smart-scene-preview-status {
+  padding: 2px 6px;
+  border-radius: 6px;
+  background: var(--chat-bg-tertiary);
+  color: var(--chat-text-secondary);
+  font-weight: 600;
+}
+
+.ai-smart-scene-preview-status--passed {
+  color: var(--chat-success);
+}
+
+.ai-smart-scene-preview-status--needs_review,
+.ai-smart-scene-preview-status--failed {
+  color: var(--chat-warning);
+}
+
+.ai-smart-scene-preview-summary,
+.ai-smart-scene-preview-more {
+  padding: 8px 12px;
+  color: var(--chat-text-secondary);
+  font-size: 12px;
+  line-height: 1.45;
+}
+
+.ai-smart-scene-preview-table {
+  max-height: 360px;
+  overflow: auto;
+
+  table {
+    width: 100%;
+    border-collapse: collapse;
+    table-layout: fixed;
+    font-size: 12px;
+  }
+
+  th,
+  td {
+    padding: 7px 8px;
+    border-top: 1px solid var(--chat-border);
+    text-align: left;
+    vertical-align: middle;
+    overflow: hidden;
+    text-overflow: ellipsis;
+    white-space: nowrap;
+  }
+
+  th {
+    color: var(--chat-text-secondary);
+    font-weight: 700;
+    background: var(--chat-bg-tertiary);
+  }
+
+  .col-index {
+    width: 32px;
+    color: var(--chat-text-muted);
+  }
+
+  .col-type {
+    width: 120px;
+  }
+
+  .col-range {
+    width: 156px;
+  }
+
+  .col-duration,
+  .col-role,
+  .col-confidence {
+    width: 74px;
+  }
+
+  .col-process {
+    width: 160px;
+  }
+}
+
+.ai-smart-scene-row--context {
+  color: var(--chat-text-secondary);
+}
+
+.ai-smart-scene-dot {
+  display: inline-block;
+  width: 7px;
+  height: 7px;
+  margin-right: 6px;
+  border-radius: 50%;
+  background: var(--chat-text-muted);
+  vertical-align: 1px;
+}
+
+.ai-smart-scene-dot--good {
+  background: var(--chat-success);
+}
+
+.ai-smart-scene-dot--warning {
+  background: var(--chat-warning);
+}
+
+.ai-smart-scene-dot--bad {
+  background: var(--chat-error);
+}
+
+.ai-smart-inline-actions-title {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  margin-bottom: 8px;
+  color: var(--chat-text-secondary);
+  font-size: 12px;
+  font-weight: 600;
+
+  .pf-icon {
+    font-size: 14px !important;
+  }
+}
+
+.ai-smart-inline-button-row {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 6px;
+}
+
+.ai-smart-inline-btn {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+  min-height: 28px;
+  padding: 4px 10px;
+  border: 1px solid var(--chat-border);
+  border-radius: 6px;
+  background: var(--chat-bg-secondary);
+  color: var(--chat-text);
+  font-size: 12px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
+
+  .pf-icon {
+    font-size: 14px !important;
+  }
+
+  &:hover:not(:disabled) {
+    color: var(--chat-primary);
+    border-color: var(--chat-primary);
+    background: var(--chat-bg-tertiary);
+  }
+
+  &:active:not(:disabled) {
+    transform: translateY(1px);
+  }
+}
+
+// Selection analysis button — contextual CTA that appears when the user has
+// a Perfetto selection. Uses the warning intent so the orange reads as
+// "you have something selected, act on it" without the vivid SaaS-style
+// gradient of the original.
+.ai-selection-btn {
+  background: var(--chat-warning);
+  color: var(--pf-color-text-on-warning);
+  border-color: var(--chat-warning);
+  font-weight: 600;
+  animation: selection-btn-pulse 2s ease-in-out infinite;
+
+  .pf-icon {
+    color: var(--pf-color-text-on-warning);
+  }
+
+  &:hover:not(:disabled) {
+    background: shade(var(--chat-warning), 88%);
+    border-color: shade(var(--chat-warning), 88%);
+    box-shadow: 0 2px 8px tint(var(--chat-warning), 40%);
+    animation: none;
+  }
+}
+
+@keyframes selection-btn-pulse {
+  0%,
+  100% {
+    opacity: 1;
+  }
+  50% {
+    opacity: 0.85;
+  }
+}
+
+// Teaching button — uses accent (mid blue) so it stays distinct from both
+// the slate-blue primary CTA (send) and the orange warning CTA (selection).
+.ai-teaching-btn {
+  background: var(--pf-color-accent);
+  color: var(--pf-color-text-on-accent);
+  border-color: var(--pf-color-accent);
+  font-weight: 600;
+
+  .pf-icon {
+    color: var(--pf-color-text-on-accent);
+  }
+
+  &:hover:not(:disabled) {
+    background: shade(var(--pf-color-accent), 88%);
+    border-color: shade(var(--pf-color-accent), 88%);
+    box-shadow: 0 2px 8px tint(var(--pf-color-accent), 40%);
+  }
+}
+
+.ai-header-actions {
+  display: flex;
+  align-items: center;
+  gap: 6px;
+  margin-left: auto;
+  min-width: 0;
+  flex-shrink: 0;
+}
+
+.ai-header-action-group {
+  display: flex;
+  align-items: center;
+  gap: 4px;
+  min-height: 30px;
+  padding: 2px 5px;
+  border: 1px solid var(--chat-border);
+  border-radius: 8px;
+  background: var(--chat-bg-secondary);
+  flex-shrink: 0;
+
+  &--analysis {
+    background: tint(var(--pf-color-accent), 6%);
+  }
+
+  &--session {
+    background: tint(var(--chat-success), 7%);
+  }
+
+  &--window {
+    background: tint(var(--pf-color-primary), 8%);
+  }
+}
+
+.ai-header-action-group-label {
+  color: var(--chat-text-secondary);
+  font-size: 10px;
+  font-weight: 600;
+  line-height: 1;
+  padding: 0 3px;
+  white-space: nowrap;
+}
+
+.ai-header-icon-btn {
+  min-width: 24px;
+  height: 24px;
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  gap: 3px;
+  background: transparent;
+  border: none;
+  border-radius: 5px;
+  color: var(--chat-text-secondary);
+  cursor: pointer;
+  transition: all 0.15s ease;
+  padding: 0 5px;
+  font-size: 11px;
+  font-weight: 600;
+  white-space: nowrap;
+
+  .pf-icon {
+    font-size: 16px !important;
+  }
+
+  &:hover:not(:disabled) {
+    background: var(--chat-bg-secondary);
+    color: var(--chat-text);
+  }
+
+  &:active:not(:disabled) {
+    transform: scale(0.95);
+  }
+
+  &:disabled,
+  &.uploading {
