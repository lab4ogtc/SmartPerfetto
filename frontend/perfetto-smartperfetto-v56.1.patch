+
+    ctx.addMessage({
+      id: ctx.generateId(),
+      role: 'assistant',
+      content: `⏳ 🔄 ${message} (${round}/${maxRounds})`,
+      timestamp: Date.now(),
+      flowTag: 'progress_note',
+    });
+  }
+  return {};
+}
