+/**
+ * Chart Configuration
+ */
+export interface ChartConfig {
+  type: 'line' | 'bar' | 'pie' | 'scatter' | 'heatmap';
+  data: unknown;
+  options?: Record<string, unknown>;
+}
+
+/**
+ * Summary Content
+ */
+export interface SummaryContent {
+  title: string;
+  content: string;
