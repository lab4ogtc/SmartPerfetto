+// ----------------------------------------------------------------------------
+// Story Reconstruction View
+// ----------------------------------------------------------------------------
+
+.ai-story-body {
+  padding: 24px;
+  max-width: 720px;
+  margin: 0 auto;
+  overflow-y: auto;
+  height: 100%;
+}
+
+// Status cards shown in the Story view (no trace / previewing / preview_cold /
+// running / completed / failed). Each modifier picks an intent from the token
+// palette so the card looks correct in both light and dark mode.
+.ai-story-card {
+  margin-top: 16px;
+  padding: 16px;
+  border-radius: 8px;
+
+  &--warn {
+    background: tint(var(--chat-warning), 12%);
+    color: var(--chat-warning);
+  }
+  &--info {
+    background: tint(var(--pf-color-accent), 10%);
+    color: var(--pf-color-accent);
+  }
+  &--success {
+    background: tint(var(--chat-success), 10%);
+    color: var(--chat-success);
+  }
+  &--error {
+    background: tint(var(--chat-error), 10%);
+    color: var(--chat-error);
+  }
+  // Cold-preview card is not a "status" — it's a confirm dialog wrapper, so
+  // it uses a softer accent surface with a visible border.
+  &--cold-preview {
+    background: tint(var(--pf-color-accent), 6%);
+    border: 1px solid tint(var(--pf-color-accent), 25%);
+  }
+}
+
+.ai-story-cold-preview-title {
+  font-weight: 600;
+  margin-bottom: 12px;
+  color: var(--pf-color-accent);
+}
+
+.ai-story-cold-preview-metrics {
+  display: flex;
+  gap: 24px;
+  margin-bottom: 16px;
+}
+
+.ai-story-cold-preview-actions {
+  display: flex;
+  gap: 8px;
+}
+
+.ai-story-hint {
+  font-size: 12px;
+  color: var(--chat-text-muted);
+  margin-bottom: 12px;
+}
+
+.ai-story-estimate-metric {
+  &-value {
+    font-size: 24px;
+    font-weight: 700;
+    color: var(--pf-color-accent);
+  }
+  &-label {
+    font-size: 12px;
+    color: var(--chat-text-secondary);
+  }
+}
+
+// Action buttons inside Story view. Primary is solid slate-blue, secondary is
+// a muted ghost, and the two "ghost" variants are link-like cancel/retry
+// affordances that tint on hover.
+.ai-story-btn-primary {
+  padding: 10px 24px;
+  font-size: 15px;
+  cursor: pointer;
+  background: var(--chat-solid-primary);
+  color: var(--chat-user-text);
+  border: none;
+  border-radius: 8px;
+  font-weight: 600;
+}
+
+.ai-story-btn-secondary {
+  padding: 10px 16px;
+  font-size: 15px;
+  cursor: pointer;
+  background: transparent;
+  color: var(--chat-text-secondary);
+  border: 1px solid var(--chat-border);
+  border-radius: 8px;
+}
+
+.ai-story-btn-ghost-danger {
+  margin-top: 12px;
+  padding: 8px 16px;
+  font-size: 13px;
+  cursor: pointer;
+  background: transparent;
+  color: var(--chat-error);
+  border: 1px solid tint(var(--chat-error), 40%);
+  border-radius: 6px;
+}
+
+.ai-story-btn-retry {
+  margin-top: 12px;
+  padding: 8px 16px;
+  font-size: 13px;
+  cursor: pointer;
+  background: var(--chat-solid-primary);
+  color: var(--chat-user-text);
+  border: none;
+  border-radius: 6px;
+}
+
+.ai-story-btn-ghost-accent {
+  margin-top: 12px;
+  padding: 8px 16px;
+  font-size: 13px;
+  cursor: pointer;
+  background: transparent;
+  color: var(--pf-color-accent);
+  border: 1px solid tint(var(--pf-color-accent), 40%);
+  border-radius: 6px;
+}
+
+// Inline scene table shown after a completed Story analysis. Previously this
+// was rendered with hardcoded dark-slate inline styles (#1e293b / #334155 /
+// #94a3b8 / #e2e8f0) that targeted an imagined dark background, but actually
+// landed on a light-grey surface causing latent contrast issues. This class
+// ties the table to the chat-bg/chat-text tokens so it renders correctly in
+// both light and dark mode.
+.ai-story-scenes-table {
+  margin-top: 16px;
+  padding: 16px;
+  border-radius: 8px;
+  background: var(--chat-bg-secondary);
+  overflow-x: auto;
+
+  table {
+    width: 100%;
+    border-collapse: collapse;
+    font-size: 13px;
+  }
+
+  thead tr {
+    border-bottom: 1px solid var(--chat-border);
+  }
+
+  th {
+    padding: 8px 12px;
+    text-align: left;
+    color: var(--chat-text-muted);
+    font-weight: 500;
+  }
+
+  tbody tr {
+    border-bottom: 1px solid var(--chat-border-light);
+    cursor: pointer;
+  }
+
+  td {
+    padding: 6px 12px;
+  }
+
+  .col-index {
+    color: var(--chat-text-secondary);
+  }
+  .col-type,
+  .col-duration {
+    color: var(--chat-text);
+  }
+  .col-duration {
+    font-variant-numeric: tabular-nums;
+  }
+  .col-process {
+    color: var(--chat-text-muted);
+    max-width: 200px;
+    overflow: hidden;
+    text-overflow: ellipsis;
+  }
+}
+
+// Per-scene state chip displayed in the right-most column of the table above.
+.ai-story-scene-state {
+  font-size: 11px;
+  padding: 2px 6px;
+  border-radius: 4px;
+
+  &--completed {
+    background: tint(var(--chat-success), 18%);
+    color: var(--chat-success);
+  }
+  &--failed {
+    background: tint(var(--chat-error), 18%);
+    color: var(--chat-error);
+  }
+  &--pending {
+    background: var(--chat-bg-tertiary);
+    color: var(--chat-text-muted);
+  }
+}
+
+// ============================================================================
+// Right Sidebar — docked AI panel (mode === 'sidebar')
+// ============================================================================
+
+// Collapsed strip — 36px vertical bar on the right edge.
+.ai-sidebar-collapsed {
+  position: fixed;
+  top: var(--topbar-height);
+  right: 0;
+  bottom: 0;
+  width: 36px;
+  z-index: 80;
+  background: var(--pf-sidebar-surface, #262f3c);
+  color: var(--pf-sidebar-on-surface, #c8c8c8);
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  padding-top: 12px;
+  gap: 8px;
+  cursor: pointer;
