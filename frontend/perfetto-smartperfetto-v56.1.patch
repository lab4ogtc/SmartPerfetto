+    max-height: 280px;
+    width: 100%;
+    overflow-x: auto;
+  }
+
+  .sql-result-table {
+    width: 100%;
+    min-width: 300px; // Minimum width for consistent appearance
+    table-layout: fixed; // Fixed layout to prevent column header wrapping
+
+    th,
+    td {
+      padding: 3px 6px;
