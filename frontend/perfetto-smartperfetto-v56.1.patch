+          matchBy: 'name',
+          mainThreadOnly: true,
+          smartPin: true,
+          activeProcessNames: ['com.example.app'],
+        }),
+        expect.objectContaining({
+          pattern: 'surfaceflinger',
+          matchBy: 'path',
+          smartPin: true,
+          activeProcessNames: ['surfaceflinger'],
+        }),
+      ]),
+    );
+  });
+});
diff --git a/ui/src/plugins/com.smartperfetto.AIAssistant/ai_shared_state.ts b/ui/src/plugins/com.smartperfetto.AIAssistant/ai_shared_state.ts
