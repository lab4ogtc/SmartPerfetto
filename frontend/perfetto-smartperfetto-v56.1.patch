+              padding: '10px 20px',
+              cursor: 'pointer',
+            },
+            onclick: () => {
+              this.effectiveExpanded = !this.effectiveExpanded;
+              if (this.effectiveExpanded && !this.effectiveConfig) {
+                this.loadEffectiveConfig();
+              }
+            },
+          },
+          [
+            m(
+              'span',
