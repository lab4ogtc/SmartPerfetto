+                  onclick: () => {
+                    vnode.attrs.onWorkspaceChange(this.workspaceId);
+                    vnode.attrs.onSave(this.settings);
+                  },
+                },
+                '\u{1F4BE} Save Settings',
+              ),
+            ])
+          : null,
+      ]),
+    );
+  }
+}
