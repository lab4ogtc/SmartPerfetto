+// ----------------------------------------------------------------------------
+// Settings Modal — keyframes used by inline styles in settings_modal.ts
+// (the .settings-modal-* class selectors were removed as dead code; the
+// component uses MODAL_STYLES inline objects with var(--chat-*) tokens)
+// ----------------------------------------------------------------------------
+
+@keyframes fadeIn {
+  from {
+    opacity: 0;
+  }
+  to {
+    opacity: 1;
+  }
+}
+
+@keyframes slideUp {
+  from {
+    opacity: 0;
+    transform: translateY(20px) scale(0.98);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0) scale(1);
+  }
+}
+
+@keyframes fadeSlideIn {
+  from {
+    opacity: 0;
+    transform: translateX(6px);
+  }
+  to {
+    opacity: 1;
+    transform: translateX(0);
+  }
+}
